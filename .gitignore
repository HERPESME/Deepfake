# Deepfake Detection Project - .gitignore

####################
# Environment / OS
####################
# Virtual environments
.venv/
venv/
env/
deepfake_env/

# Environment variable files
.env
.env.*
*.env

# macOS
.DS_Store

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

####################
# Python
####################
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# Type checking
.mypy_cache/

####################
# Datasets (large - download separately)
####################
data/raw/
data/processed/
data/splits/

####################
# Model weights (large binaries)
####################
**/*.pth
**/*.pt
*.ckpt
*.h5
*.onnx
*.tflite
*.bin
*.safetensors
checkpoints/

####################
# Experiment outputs
####################
experiments/
logs/
*.log

# Weights & Biases / TensorBoard
wandb/
runs/
tensorboard/

####################
# Large media files
####################
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.avi
*.mov
*.mkv

####################
# Generated / temporary
####################
*.tmp
*.temp
*.bak
*.backup
temp/
tmp/

# Generated reports (can be re-created from scripts)
reports/
